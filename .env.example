# App runtime
LIFENODE_HOST=0.0.0.0
LIFENODE_PORT=8000
LIFENODE_WORKERS=1
LIFENODE_LOG_LEVEL=INFO
LIFENODE_WIKI_LANG=en
LIFENODE_CORS_ORIGINS=*

# Storage locations inside the container
LIFENODE_DATA_DIR=/app/data
LIFENODE_DB_PATH=/app/data/lifenode.db
LIFENODE_DRIVE_DIR=/app/data/drive

# Upload size limit in MB
LIFENODE_MAX_UPLOAD_MB=100

# Optional model files (mounted from ./models)
LIFENODE_LLM_MODEL_PATH=/models/Qwen3.5-0.8B-UD-Q3_K_XL.gguf
LIFENODE_EMBED_MODEL_PATH=/models/embeddinggemma-300M-Q8_0.gguf

# Build-time flag (used by compose build args)
INSTALL_LLM_BACKEND=1

