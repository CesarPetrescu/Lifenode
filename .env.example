LIFENODE_HOST=0.0.0.0
LIFENODE_PORT=8000
LIFENODE_WIKI_LANG=en
LIFENODE_WIKI_USER_AGENT=LifeNode/1.0 (+https://github.com/CesarPetrescu/LifeNode)
LIFENODE_ADMIN_USERNAME=
LIFENODE_ADMIN_PASSWORD=

LIFENODE_DB_PATH=/data/user-files/lifenode.db
LIFENODE_USER_FILES_DIR=/data/user-files
LIFENODE_FRONTEND_DIST=/app/frontend/dist

LIFENODE_MAX_UPLOAD_MB=100
LIFENODE_CORS_ORIGINS=*
LIFENODE_KIWIX_EMBED_URL=http://localhost:8081
LIFENODE_KIWIX_PORT=8081

# llama.cpp OpenAI-compatible endpoints used by backend
LIFENODE_LLAMACPP_EMBED_URL=http://llama-embed:8080/v1/embeddings
LIFENODE_LLAMACPP_EMBED_MODEL=embeddinggemma-300M-Q8_0.gguf
LIFENODE_LLAMACPP_CHAT_URL=http://llama-qwen:8080/v1/chat/completions
LIFENODE_LLAMACPP_CHAT_MODEL=Qwen3.5-0.8B-UD-Q3_K_XL.gguf
LIFENODE_LLAMACPP_API_KEY=
LIFENODE_LLAMACPP_CHAT_MAX_TOKENS=1024
LIFENODE_LLAMACPP_CHAT_TIMEOUT_SECS=120
LIFENODE_LLAMACPP_CHAT_THINKING_DEFAULT=false

# llama.cpp server runtime args
LLAMACPP_QWEN_MODEL_PATH=/models/Qwen3.5-0.8B-UD-Q3_K_XL.gguf
LLAMACPP_EMBED_MODEL_PATH=/models/embeddinggemma-300M-Q8_0.gguf
LLAMACPP_QWEN_CTX=4096
LLAMACPP_EMBED_CTX=2048
LLAMACPP_NGL=0
